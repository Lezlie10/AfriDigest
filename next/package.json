{
  "name": "afridigest-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3000",
    "build": "next build",
    "vercel-build": "next build",
    "start": "next start -p 3000",
    "deploy:check": "node scripts/check-deploy-env.mjs",
    "db:migrate-json": "node scripts/migrate-json-to-postgres.mjs",
    "db:init": "node -e \"const fs=require('fs');const path=require('path');const {Pool}=require('pg');const sql=fs.readFileSync(path.join(process.cwd(),'sql','schema.sql'),'utf8');const pool=new Pool({connectionString:process.env.DATABASE_URL});pool.query(sql).then(()=>{console.log('Schema initialized')}).catch((err)=>{console.error(err);process.exitCode=1}).finally(()=>pool.end())\""
  },
  "dependencies": {
    "next": "latest",
    "nodemailer": "latest",
    "pg": "^8.16.3",
    "react": "latest",
    "react-dom": "latest",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
