# Public site URL used for metadata, robots, and sitemap
NEXT_PUBLIC_SITE_URL=https://afridigest.example.com

# Postgres connection string for persistent production storage.
# When omitted, the app falls back to local JSON files in /content.
DATABASE_URL=postgres://user:password@localhost:5432/afridigest

# Required for secure cookie session signing (set a long random value in production)
AUTH_SECRET=replace-with-a-strong-random-secret

# Admin token for article publishing API
ADMIN_TOKEN=replace-with-a-long-admin-token
# Optional allowlist for admin-only APIs/pages (comma-separated emails)
ADMIN_EMAILS=admin@example.com

# Stripe paid subscription settings (required for paid subscribe flow)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID=price_replace_me

# Paystack paid subscription settings (recommended for Nigeria)
PAYSTACK_SECRET_KEY=sk_test_replace_me
# Use either recurring plan code OR one-time amount in kobo
PAYSTACK_PLAN_CODE=plan_replace_me
PAYSTACK_AMOUNT_KOBO=500000

# Manual subscription fallback (no payment gateway)
MANUAL_SUBSCRIPTION_ENABLED=true
# Keep false for manual transfer fraud safety (approve only after real bank credit verification)
AUTO_APPROVE_MANUAL_SUBSCRIPTIONS=false
MANUAL_SUBSCRIPTION_AMOUNT_NGN=5000
MANUAL_BANK_NAME=Your Bank
MANUAL_BANK_ACCOUNT_NAME=AfriDigest Media
MANUAL_BANK_ACCOUNT_NUMBER=0000000000

# Optional SMTP settings for password reset emails
SMTP_SERVICE=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=AfriDigest <no-reply@example.com>
